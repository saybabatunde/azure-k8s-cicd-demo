# Copy this file to terraform.tfvars and fill in your values
# DO NOT COMMIT terraform.tfvars to version control (add to .gitignore)

# Azure subscription ID (required)
azure_subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Resource naming
resource_group_name = "azure-k8s-cicd-rg"
cluster_name        = "azure-k8s-cicd"
location            = "eastus"
environment         = "dev"
project_name        = "azure-k8s-cicd-demo"

# Kubernetes version
kubernetes_version = "1.28"

# Networking
vnet_cidr          = "10.0.0.0/16"
subnet_cidr        = "10.0.1.0/24"
service_cidr       = "10.1.0.0/16"
dns_service_ip     = "10.1.0.10"
docker_bridge_cidr = "172.17.0.1/16"

# Node pool configuration
node_count          = 2
vm_size             = "Standard_B2s"
enable_auto_scaling = true
min_node_count      = 1
max_node_count      = 5

# Container Registry
acr_sku = "Standard"

# Optional: enable additional node pool
enable_optional_node_pool = false
optional_vm_size          = "Standard_B2s"
optional_node_count       = 1

# Monitoring & Alerts
alert_email = "your-email@example.com"
